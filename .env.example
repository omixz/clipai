SITE_URL=https://peakcut.duckdns.org
# Direct bank transfer (Australian domestic transfer -- BSB + account
# number) -- the active billing path, no processor/ID verification needed.
# Upgrades are granted manually via /admin/billing once a payment with the
# matching reference lands. Unlike US ACH, an Australian BSB + account
# number alone can't be used to pull/debit money out of the account (that
# needs a separate Direct Debit Request authority set up with the payer),
# so publishing them is normal/low-risk -- it's what an invoice shows too.
BANK_NAME=...
BANK_ACCOUNT_NAME=...
BANK_ACCOUNT_NUMBER=...
BANK_BSB=...
# BANK_PAYID=...   # optional -- e.g. your phone/email registered for PayID; PayID/Osko transfers settle near-instantly via Australia's NPP instead of the ~1 business day a standard transfer can take
# PayPal -- optional, alongside/instead of bank transfer once set up.
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox              # "sandbox" while testing, "live" once real payments should work
# PAYPAL_PLAN_ID_PRO=P-...
# PAYPAL_PLAN_ID_PLUS=P-...
# PAYPAL_WEBHOOK_ID=...
ADSENSE_PUBLISHER_ID=ca-pub-5158161193547085
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
SESSION_SECRET_KEY=...
RESEND_API_KEY=re_...
EMAIL_FROM=Peakcut <onboarding@resend.dev>
CONTACT_EMAIL=support@peakcut.example
FREE_LIMIT=1
# PRO_LIMIT=20
# PRO_PLUS_LIMIT=50
# API_FREE_LIMIT=100
# API_PRO_LIMIT=500
# API_PRO_PLUS_LIMIT=2000
MAX_UPLOAD_MB=300
# MAX_VIDEO_DURATION_MIN=45
# WHISPER_MODEL=tiny        # base/small on a host with more RAM (e.g. Oracle) for better accuracy
WORKER_COUNT=2              # concurrent job processing -- see README's Oracle section; safe to raise up to your OCPU count
# BACKGROUND_UPLOAD_MB=50           # split-screen custom background upload cap (Pro/Pro Plus)
# MAX_BACKGROUND_DURATION_SEC=60   # split-screen custom background duration cap
# BACKGROUNDS_DIR=./assets/backgrounds  # see that folder's README before the split-screen feature actually works
# ADMIN_EMAILS=you@example.com   # comma-separated; these Google accounts get Pro Plus free, no PayPal subscription needed -- requires GOOGLE_CLIENT_ID/SECRET above to be real (sign-in has to actually work) and you to sign in with that exact email

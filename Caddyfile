# Caddy gets and renews an HTTPS certificate automatically (Let's Encrypt) for
# whatever hostname is here — replace with your real domain or free DuckDNS
# hostname (e.g. peakcut.duckdns.org) before starting. A bare IP address
# cannot get a valid certificate; you need *some* DNS hostname pointing here.
your-hostname-here.duckdns.org {
	reverse_proxy app:8000
}
